{
  "model": "opus",
  "fallbackModel": ["sonnet"],
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git merge:*)",
      "Bash(git clone:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(bash scripts/memory-search.sh*)",
      "Bash(bash scripts/audit-context.sh*)",
      "Bash(bash scripts/scrub-secrets.sh*)",
      "Bash(bash scripts/validate-roadmap.sh*)",
      "Bash(bash scripts/create-pr.sh*)",
      "Bash(bash scripts/dashboard.sh*)",
      "Bash(bash scripts/context-filter.sh*)",
      "Bash(bash scripts/validate-freshness.sh*)",
      "Bash(bash scripts/codex-review.sh*)",
      "Bash(bash scripts/generate-manifest.sh*)",
      "Bash(bash scripts/update-project.sh*)",
      "Bash(bash scripts/sync-hooks.sh*)",
      "Bash(bash scripts/maintain.sh*)",
      "Bash(bash scripts/dream-accept.sh*)",
      "Bash(bash scripts/install-hooks.sh*)",
      "Bash(bash scripts/install-global-commands.sh*)",
      "Bash(bash scripts/new-project.sh*)",
      "Bash(bash scripts/setup.sh*)",
      "Bash(bash tests/*)",
      "Bash(bash .claude/hooks/post-mcp-validate.sh*)",
      "Bash(bash .claude/hooks/post-tool-use.sh*)",
      "Bash(bash .claude/hooks/post-write-session.sh*)",
      "Bash(bash .claude/hooks/output-index.sh*)",
      "Bash(bash .claude/hooks/tool-failure-log.sh*)",
      "Bash(bash .claude/hooks/compact-suggest.sh*)",
      "Bash(bash .claude/hooks/pre-compact.sh*)",
      "Bash(bash .claude/hooks/session-start-setup.sh*)",
      "Bash(bash .claude/hooks/session-start-maintain.sh*)",
      "Bash(bash .claude/hooks/session-end-cleanup.sh*)",
      "Bash(bash .claude/hooks/notify-phase-change.sh*)",
      "Bash(bash .claude/hooks/log-activity.sh*)",
      "Bash(node scripts/knowledge-index.ts*)",
      "Bash(node scripts/dashboard-server.ts*)",
      "Bash(node scripts/observation-parser.ts*)",
      "Bash(node scripts/security-scanner.ts*)",
      "Bash(node scripts/system-map.ts*)",
      "Bash(node scripts/maintain-draft.ts*)",
      "Bash(node scripts/detect-stack.ts*)",
      "Bash((cd * && *))",
      "Bash((cd * ; *))",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": []
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75"
  },
  "project_os": {
    "parallel": {
      "max_concurrent_agents": 4,
      "worktree_base": ".claude/worktrees",
      "auto_cleanup": true,
      "session_handoff_location": ".claude/sessions",
      "backoff": {
        "initial_delay_ms": 1000,
        "max_delay_ms": 30000,
        "multiplier": 2
      }
    },
    "compete": {
      "default_approaches": 3,
      "strategies": ["literal", "minimal", "extensible"]
    },
    "adapters": {
      "default": "native",
      "available": ["codex"],
      "fallback_on_failure": true
    },
    "dashboard": {
      "projects_root": "~/projects"
    },
    "context_filter": {
      "enabled": true,
      "threshold_bytes": 5120,
      "index_path": ".claude/index/knowledge.db",
      "max_search_results": 10,
      "freshness": {
        "stale_threshold_days": 90,
        "decay_halflife_days": 30,
        "warn_on_stale": true,
        "auto_detect_dates": true,
        "recency_halflife_days": 14
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__context7__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/post-mcp-validate.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/post-tool-use.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/post-write-session.sh\""
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/output-index.sh\""
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/tool-failure-log.sh\""
          },
          {
            "type": "command",
            "command": "bash \".claude/hooks/compact-suggest.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/pre-compact.sh\"",
            "timeout": 30,
            "statusMessage": "Saving auto-checkpoint..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/session-start-setup.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \".claude/hooks/session-start-maintain.sh\"",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/session-end-cleanup.sh\""
          }
        ]
      }
    ]
  }
}
