CLAUDE.local.md
.claude/sessions/
.claude/settings.local.json
node_modules/
.env
.env.*

# Obsidian user state (vault config is committed; workspace state is not)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Hook logs (session-local, not shared)
.claude/logs/

# Research output (may contain sensitive analysis)
docs/research/

# Feature specs (project-specific, not template content)
docs/specs/*
!docs/specs/.gitkeep

# Memory (cross-session, local only)
docs/memory/*
!docs/memory/.gitkeep

# Build output
dist/
build/

# Context filter index (rebuilt from source files)
.claude/index/

# Runtime lock files
.claude/scheduled_tasks.lock

# Update system artifacts
.claude/backups/
*.upstream

# Security: dangerous file types (private keys, certificates, credentials)
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
id_rsa*
*.jks
credentials.*
!credentials.example.*
